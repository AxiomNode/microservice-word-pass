generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Stores AI-generated game content and its generation metadata
model GameGeneration {
  /// Unique identifier for the generation record
  id           String   @id @default(cuid())
  gameType     String
  query        String
  status       String
  /// Optional reference to a game category
  categoryId    String?
  categoryName  String?
  /// Deduplication key to prevent duplicate generations
  uniquenessKey String?  @unique
  /// Groups generations belonging to the same batch run
  batchRunId    String?
  difficultyPercentage Int?
  requestJson  String
  responseJson String
  createdAt    DateTime @default(now())

  @@index([gameType, createdAt])
  @@index([gameType, difficultyPercentage, createdAt])
  @@index([gameType, categoryId, createdAt])
  @@index([gameType, categoryId, difficultyPercentage, createdAt])
}
